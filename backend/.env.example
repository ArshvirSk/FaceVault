# Backend environment variables
# Copy this file to .env and fill in your values.
# Load with: uvicorn main:app --reload  (python-dotenv not required; set vars in your shell or use a .env loader)
#
# The URL of the frontend (used for CORS).
# - Local development (default): http://localhost:3000
# - Another device on the LAN:   http://192.168.1.10:3000
#                                  (use `ipconfig` / `ip a` to find the host machine IP)
# - Custom domain:               https://facevault.example.com
#
FRONTEND_URL=http://localhost:3000
