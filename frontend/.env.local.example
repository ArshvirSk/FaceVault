# Frontend environment variables
# Copy this file to .env.local and fill in your values.
#
# The URL of the FaceVault backend API.
# - Local development (default):  http://localhost:8000
# - Another device on the LAN:    http://192.168.1.42:8000
#                                  (use `ipconfig` / `ip a` to find the host IP)
# - Custom domain / reverse proxy: https://facevault.example.com
#
NEXT_PUBLIC_API_URL=http://localhost:8000
